---
import { getCollection } from "astro:content";

const wikis = await getCollection("wikis");
wikis.sort((a, b) =>
  (b.data.last_updated ?? "").localeCompare(a.data.last_updated ?? ""),
);

function formatStars(n: number | undefined): string {
  if (typeof n !== "number") return "";
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return String(n);
}

function repoLabel(url: string | undefined, fallback: string): string {
  if (url) {
    const m = url.match(/github\.com[/:]([^/]+)\/([^/.]+)/);
    if (m) return `${m[1]}/${m[2]}`;
  }
  return fallback;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Deep Wikis</title>
    <meta
      name="description"
      content="Repository deep-wikis generated by auggie-deep-wiki."
    />
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="brand">CONTEXTWIKI</p>
        <h1>The AI knowledge base for open source</h1>
        <p class="lead">
          Navigate {wikis.length} top repositories with Augment Code. From
          architecture overviews to function-level insights, everything is
          just one click away.
        </p>
        <div class="search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input id="wiki-search" type="search" placeholder="Search repositories..." autocomplete="off" spellcheck="false" />
        </div>
      </section>

      <hr class="divider" />

      {wikis.length === 0 ? (
        <p class="empty">
          No wikis published yet. Run the skill with <code>--publish-git</code> to populate this site.
        </p>
      ) : (
        <section class="grid" id="wiki-grid">
          {wikis.map((entry) => {
            const label = repoLabel(entry.data.repo_url, entry.data.title);
            const haystack = [
              label,
              entry.data.title,
              entry.data.description,
              entry.data.language,
              ...(entry.data.topics ?? []),
            ].filter(Boolean).join(" ").toLowerCase();
            return (
              <a class="card" href={`/wikis/${entry.id.replace(/\/index$/, "")}/`} data-search={haystack}>
                <div class="card-title">{label}</div>
                {entry.data.description && <p class="card-desc">{entry.data.description}</p>}
                {typeof entry.data.stars === "number" && (
                  <div class="card-stars">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <span>{formatStars(entry.data.stars)}</span>
                  </div>
                )}
              </a>
            );
          })}
        </section>
      )}

      <p id="wiki-empty" class="empty-results" hidden>No repositories match your search.</p>
    </main>

    <script is:inline>
      (function () {
        const input = document.getElementById("wiki-search");
        const grid = document.getElementById("wiki-grid");
        const empty = document.getElementById("wiki-empty");
        if (!input || !grid) return;
        const cards = Array.from(grid.querySelectorAll(".card"));
        function apply() {
          const q = input.value.trim().toLowerCase();
          let visible = 0;
          for (const card of cards) {
            const hay = card.getAttribute("data-search") || "";
            const match = !q || hay.includes(q);
            card.hidden = !match;
            if (match) visible++;
          }
          if (empty) empty.hidden = visible !== 0 || cards.length === 0;
        }
        input.addEventListener("input", apply);
      })();
    </script>

    <style>
      :root {
        color-scheme: dark;
        --fg: #f5f5f5;
        --bg: #000000;
        --muted: #8a8a8a;
        --border: #1f1f1f;
        --border-strong: #2a2a2a;
        --accent: #4ade80;
        --field-bg: #111111;
      }
      html, body { background: var(--bg); color: var(--fg); margin: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; line-height: 1.5; -webkit-font-smoothing: antialiased; }
      main { max-width: 1280px; margin: 0 auto; padding: 4rem 2rem 6rem; }

      .hero { padding: 1rem 0 3rem; }
      .brand { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.8rem; letter-spacing: 0.1em; color: var(--accent); margin: 0 0 2rem; }
      .hero h1 { font-size: clamp(2.25rem, 6vw, 5rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 2rem; max-width: 18ch; }
      .lead { color: var(--muted); font-size: 1.05rem; max-width: 60ch; margin: 0 0 2.5rem; }

      .search { position: relative; max-width: 720px; }
      .search svg { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--muted); width: 18px; height: 18px; pointer-events: none; }
      .search input { width: 100%; box-sizing: border-box; padding: 1rem 1rem 1rem 2.75rem; background: var(--field-bg); color: var(--fg); border: 1px solid var(--border); border-radius: 6px; font-size: 1rem; outline: none; transition: border-color 0.15s; }
      .search input::placeholder { color: var(--muted); }
      .search input:focus { border-color: var(--border-strong); }

      .divider { border: 0; border-top: 1px solid var(--border); margin: 0; }

      .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; margin-top: 4rem; }
      @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
      @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }

      .card { display: flex; flex-direction: column; gap: 0.75rem; padding: 1.5rem; border: 1px solid var(--border); border-radius: 4px; text-decoration: none; color: var(--fg); background: transparent; transition: border-color 0.15s, background 0.15s; min-height: 200px; }
      .card:hover { border-color: var(--border-strong); background: rgba(255,255,255,0.02); }
      .card-title { font-size: 1rem; font-weight: 500; color: var(--fg); }
      .card-desc { color: var(--muted); font-size: 0.9rem; margin: 0; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .card-stars { display: flex; align-items: center; gap: 0.4rem; color: var(--muted); font-size: 0.85rem; margin-top: auto; }
      .card-stars svg { width: 14px; height: 14px; }

      .empty { color: var(--muted); padding: 2rem; border: 1px dashed var(--border); border-radius: 6px; margin-top: 3rem; }
      .empty-results { color: var(--muted); text-align: center; margin: 3rem 0; }
    </style>
  </body>
</html>
