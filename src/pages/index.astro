---
import { getCollection } from "astro:content";

const wikis = await getCollection("wikis");
wikis.sort((a, b) =>
  (b.data.last_updated ?? "").localeCompare(a.data.last_updated ?? ""),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Deep Wikis</title>
    <meta
      name="description"
      content="Repository deep-wikis generated by auggie-deep-wiki."
    />
  </head>
  <body>
    <main>
      <header>
        <h1>Deep Wikis</h1>
        <p>
          Generated by{" "}
          <a
            href="https://github.com/augment-solutions/auggie-skills"
            target="_blank"
            rel="noopener">auggie-deep-wiki</a
          >. Each entry is a multi-section MDX guide to a Git repository.
        </p>
      </header>

      {wikis.length === 0 && (
        <p class="empty">
          No wikis published yet. Run the skill with
          <code>--publish-vercel</code> to populate this site.
        </p>
      )}

      <ul class="wiki-list">
        {wikis.map((entry) => (
          <li>
            <a href={`/wikis/${entry.id.replace(/\/index$/, "")}/`}>
              <strong>{entry.data.title}</strong>
              {entry.data.description && <p>{entry.data.description}</p>}
              <span class="meta">
                {entry.data.repo_url && <span>{entry.data.repo_url}</span>}
                {entry.data.last_updated && (
                  <span> · {entry.data.last_updated}</span>
                )}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <style>
      :root {
        --fg: #1f2328;
        --bg: #ffffff;
        --muted: #57606a;
        --border: #d0d7de;
        --link: #0969da;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #c9d1d9;
          --bg: #0d1117;
          --muted: #8b949e;
          --border: #30363d;
          --link: #58a6ff;
        }
      }
      html, body { background: var(--bg); color: var(--fg); margin: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
        Roboto, "Helvetica Neue", Arial, sans-serif; line-height: 1.6; }
      main { max-width: 880px; margin: 0 auto; padding: 3rem 1.5rem; }
      header { margin-bottom: 2rem; }
      header h1 { margin: 0 0 0.5rem; font-size: 2.25rem; }
      header p { color: var(--muted); margin: 0; }
      .empty { color: var(--muted); padding: 2rem;
        border: 1px dashed var(--border); border-radius: 6px; }
      .wiki-list { list-style: none; padding: 0; margin: 0;
        display: grid; gap: 1rem; }
      .wiki-list a { display: block; padding: 1rem 1.25rem;
        border: 1px solid var(--border); border-radius: 8px;
        text-decoration: none; color: var(--fg); transition: border-color 0.15s; }
      .wiki-list a:hover { border-color: var(--link); }
      .wiki-list strong { font-size: 1.1rem; color: var(--link); }
      .wiki-list p { margin: 0.5rem 0; color: var(--muted); }
      .meta { color: var(--muted); font-size: 0.85rem; }
      a { color: var(--link); }
    </style>
  </body>
</html>
